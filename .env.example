# Bluesky を情報源に追加する場合のみ設定します（未設定なら自動でスキップされます）。
# 1. Bluesky にログイン
# 2. Settings > Privacy and Security > App Passwords で「アプリパスワード」を発行
# 3. このファイルを `.env` にコピーして値を設定:  cp .env.example .env
#
# 注意: .env は .gitignore 済みです。絶対にコミットしないでください。
# （通常のログインパスワードではなく、必ず「アプリパスワード」を使うこと）

BLUESKY_HANDLE=yourname.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
